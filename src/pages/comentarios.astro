---
import { Comentario } from "astro:db";
import { db } from "astro:db";
import Layout from "../layouts/Layout.astro";
import { colors } from "../config/wedding";

const comentarios = await db.select().from(Comentario);
comentarios.sort((a, b) => {
  if (a.fecha > b.fecha) return -1;
  if (a.fecha < b.fecha) return 1;
  return 0;
});

const total = comentarios.length;
const asistiran = comentarios.filter((c) => c.asistir).length;
const noAsistiran = total - asistiran;

const formatDate = (d: Date) =>
  new Date(d).toLocaleDateString("es-MX", {
    day: "2-digit",
    month: "long",
    year: "numeric",
  });

---

<Layout>
  <div
    class="texture-overlay relative w-full min-h-screen z-30"
    style={`background-color: ${colors.bgWarm}; color: ${colors.textDark}`}
  >
    <div class="relative z-10 px-6 py-14 sm:py-20 max-w-2xl mx-auto">
      <header class="text-center">
        <p
          class="font-raleway text-xs sm:text-sm tracking-[0.35em] uppercase mb-3"
          style={`color: ${colors.textMuted}`}
        >
          Mensajes de nuestros invitados
        </p>
        <h1
          class="font-greatVibes text-5xl sm:text-6xl"
          style={`color: ${colors.primary}`}
        >
          Con cariño
        </h1>
        <div class="divider-line"></div>
      </header>

      <section class="grid grid-cols-3 gap-3 sm:gap-4 mb-10">
        <div
          class="flex flex-col items-center justify-center rounded-sm border border-double py-4"
          style={`border-color: ${colors.primaryLight}; background-color: ${colors.white}`}
        >
          <span
            class="font-cormorant text-3xl sm:text-4xl font-semibold"
            style={`color: ${colors.primary}`}>{total}</span
          >
          <span
            class="font-raleway text-[10px] sm:text-xs tracking-[0.2em] uppercase mt-1"
            style={`color: ${colors.textMuted}`}>Total</span
          >
        </div>
        <div
          class="flex flex-col items-center justify-center rounded-sm border border-double py-4"
          style={`border-color: ${colors.primaryLight}; background-color: ${colors.white}`}
        >
          <span
            class="font-cormorant text-3xl sm:text-4xl font-semibold"
            style={`color: ${colors.primary}`}>{asistiran}</span
          >
          <span
            class="font-raleway text-[10px] sm:text-xs tracking-[0.2em] uppercase mt-1"
            style={`color: ${colors.textMuted}`}>Asisten</span
          >
        </div>
        <div
          class="flex flex-col items-center justify-center rounded-sm border border-double py-4"
          style={`border-color: ${colors.primaryLight}; background-color: ${colors.white}`}
        >
          <span
            class="font-cormorant text-3xl sm:text-4xl font-semibold"
            style={`color: ${colors.primary}`}>{noAsistiran}</span
          >
          <span
            class="font-raleway text-[10px] sm:text-xs tracking-[0.2em] uppercase mt-1"
            style={`color: ${colors.textMuted}`}>No asisten</span
          >
        </div>
      </section>

      {
        total === 0 ? (
          <div
            class="text-center py-16 rounded-sm border border-dashed"
            style={`border-color: ${colors.primaryLight}; background-color: ${colors.white}`}
          >
            <p
              class="font-cormorant italic text-xl"
              style={`color: ${colors.textMuted}`}
            >
              Aún no hay mensajes.
            </p>
          </div>
        ) : (
          <ul class="flex flex-col gap-5">
            {comentarios.map((comentario) => (
              <li
                class="comment-card relative rounded-sm border border-double px-6 py-5 shadow-sm"
                style={`background-color: ${colors.white}; border-color: ${colors.primaryLight}`}
              >
                <div class="flex items-start justify-between gap-3">
                  <div class="flex items-center gap-3 min-w-0">
                    <div
                      class="flex shrink-0 items-center justify-center w-10 h-10 rounded-full font-greatVibes text-xl"
                      style={`background-color: ${colors.bgWarm}; color: ${colors.primary}; border: 1px solid ${colors.primaryLight}`}
                    >
                      {comentario.nombre.trim().charAt(0).toUpperCase()}
                    </div>
                    <div class="min-w-0">
                      <h2
                        class="font-cormorant text-xl sm:text-2xl leading-tight truncate"
                        style={`color: ${colors.textDark}`}
                      >
                        {comentario.nombre}
                      </h2>
                      <p
                        class="font-raleway text-[10px] sm:text-xs tracking-[0.2em] uppercase mt-0.5"
                        style={`color: ${colors.textMuted}`}
                      >
                        {formatDate(comentario.fecha)}
                      </p>
                    </div>
                  </div>
                  <span
                    class="shrink-0 font-raleway text-[10px] sm:text-xs tracking-[0.2em] uppercase px-2.5 py-1 rounded-full border"
                    style={
                      comentario.asistir
                        ? `color: ${colors.primary}; border-color: ${colors.primaryLight}; background-color: ${colors.bgWarm}`
                        : `color: ${colors.textMuted}; border-color: ${colors.textMuted}; background-color: transparent`
                    }
                  >
                    {comentario.asistir ? "Asistirá" : "No asistirá"}
                  </span>
                </div>

                <div class="divider-line" style="margin: 1rem auto;" />

                <p
                  class="font-cormorant italic text-lg sm:text-xl leading-relaxed text-center px-2"
                  style={`color: ${colors.textDark}`}
                >
                  &ldquo;{comentario.mensaje}&rdquo;
                </p>
              </li>
            ))}
          </ul>
        )
      }

    </div>
  </div>
</Layout>

<style>
  .comment-card {
    opacity: 0;
    transform: translateY(12px);
    transition:
      opacity 700ms ease,
      transform 700ms ease;
  }
  .comment-card.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  const cards = document.querySelectorAll(".comment-card");
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry, i) => {
        if (entry.isIntersecting) {
          setTimeout(() => entry.target.classList.add("is-visible"), i * 60);
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.15 },
  );
  cards.forEach((c) => observer.observe(c));
</script>
