---
import { colors, locations } from "../config/wedding";
---

<div class="relative z-40 texture-overlay" style={`background-color: ${colors.bgWarm}`}>
  <div class="relative z-10 py-14 sm:py-16 px-6">
    <div class="text-center mb-10">
      <p class="font-raleway text-xs sm:text-sm tracking-[0.3em] uppercase mb-3 intersect:motion-preset-blur-right-md intersect:motion-duration-1000 intersect-once" style={`color: ${colors.textMuted}`}>
        Dónde celebraremos
      </p>
      <h1
        class="font-greatVibes text-center text-6xl sm:text-7xl intersect:motion-preset-blur-up-md intersect:motion-delay-200 intersect:motion-duration-1500 intersect-once"
        style={`color: ${colors.primary}`}
      >
        Ubicaciones
      </h1>
      <div class="divider-line"></div>
    </div>

    <div class="flex justify-center max-w-3xl mx-auto">
      <!-- Reception -->
      <div class="text-center intersect:motion-preset-rebound-up intersect:motion-delay-[400ms] intersect:motion-duration-[1200ms] intersect-once">
        <p
          class="font-raleway text-xs tracking-[0.3em] uppercase mb-1"
          style={`color: ${colors.textMuted}`}
        >
          Ceremonia y Recepción
        </p>
        <p class="font-cormorant text-lg mb-4" style={`color: ${colors.primary}`}>
          {locations.reception.time}
        </p>
        <div
          class="w-44 h-44 mx-auto rounded-full overflow-hidden border-2"
          style={`border-color: ${colors.primaryLight}; box-shadow: 0 4px 25px rgba(184, 134, 11, 0.15);`}
        >
          <img
            src={locations.reception.imageUrl}
            class="w-full h-full object-cover transition-transform duration-700 hover:scale-110"
            alt="Salón"
            onerror="this.style.display='none'"
          />
        </div>
        <div class="mt-5">
          <h3
            class="font-cormorant text-2xl sm:text-3xl"
            style={`color: ${colors.textDark}`}
          >
            {locations.reception.name}
          </h3>
          <p
            class="font-raleway text-sm sm:text-base mt-1 leading-relaxed"
            style={`color: ${colors.textMuted}`}
          >
            {locations.reception.address}
          </p>
          <div class="flex justify-center mt-4">
            <a
              class="font-raleway text-white py-2.5 px-7 rounded-full text-xs tracking-[0.2em] uppercase transition-all duration-300 hover:shadow-lg hover:scale-[1.02]"
              style={`background-color: ${colors.primary}`}
              href={locations.reception.mapUrl}
            >Ver ubicación</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
