---
import { colors } from "../config/wedding";
---

<section class="texture-overlay relative" style={`background-color: ${colors.bgWarm}`}>
  <div class="relative z-10 py-16 sm:py-20 px-8">
    <div class="max-w-lg mx-auto text-center">
      <p
        class="font-raleway text-xs sm:text-sm tracking-[0.35em] uppercase mb-6 intersect:motion-preset-blur-right-md intersect:motion-duration-1000 intersect-once"
        style={`color: ${colors.textDark}; opacity: 0.6`}
      >
        Bienvenidos
      </p>
      <h1
        class="text-xl sm:text-2xl font-cormorant tracking-wide leading-relaxed intersect:motion-preset-slide-up-md intersect:motion-delay-200 intersect:motion-duration-1000 intersect-once"
        style={`color: ${colors.textDark}`}
      >
        Aquí comienza nuestro gran
      </h1>
      <h2
        class="text-4xl sm:text-5xl font-greatVibes mt-4 intersect:motion-preset-blur-up-md intersect:motion-delay-500 intersect:motion-duration-1500 intersect-once"
        style={`color: ${colors.primary}`}
      >
        "Felices para siempre"
      </h2>
      <div class="divider-line mt-8"></div>
    </div>
  </div>
</section>
