---
import { colors, parents } from "../config/wedding";
---

<div
  class="texture-overlay relative w-full z-30"
  style={`background-color: ${colors.bgWarm}; color: ${colors.textDark}`}
>
  <div class="relative z-10 py-16 sm:py-20 px-6">
    <div class="max-w-2xl mx-auto">
      <h1
        class="text-center font-greatVibes py-1 text-5xl sm:text-6xl intersect:motion-preset-blur-up-md intersect:motion-duration-1500 intersect-once"
        style={`color: ${colors.primary}`}
      >
        Con la bendición de Dios y de nuestros padres
      </h1>
      <div class="divider-line"></div>

      <div class="grid sm:grid-cols-2 grid-cols-1 gap-10 sm:gap-16 mt-10">
        <div class="intersect:motion-preset-slide-up-right-md intersect:motion-delay-300 intersect:motion-duration-1000 intersect-once">
          <p
            class="text-center font-raleway text-xs sm:text-sm tracking-[0.3em] uppercase mb-4"
            style={`color: ${colors.textMuted}`}
          >
            {parents.bride.label}
          </p>
          <p class="text-center font-cormorant text-2xl sm:text-3xl leading-relaxed">
            {parents.bride.mother}
          </p>
          <p class="text-center font-cormorant text-lg my-1 italic" style={`color: ${colors.primaryLight}`}>&</p>
          <p class="text-center font-cormorant text-2xl sm:text-3xl leading-relaxed">
            {parents.bride.father}
          </p>
        </div>

        <div class="intersect:motion-preset-slide-up-left-md intersect:motion-delay-500 intersect:motion-duration-1000 intersect-once">
          <p
            class="text-center font-raleway text-xs sm:text-sm tracking-[0.3em] uppercase mb-4"
            style={`color: ${colors.textMuted}`}
          >
            {parents.groom.label}
          </p>
          <p class="text-center font-cormorant text-2xl sm:text-3xl leading-relaxed">
            {parents.groom.mother}
          </p>
          <p class="text-center font-cormorant text-lg my-1 italic" style={`color: ${colors.primaryLight}`}>&</p>
          <p class="text-center font-cormorant text-2xl sm:text-3xl leading-relaxed">
            {parents.groom.father}
          </p>
        </div>
      </div>
    </div>
  </div>
</div>
