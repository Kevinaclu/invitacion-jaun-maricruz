---
import { colors, designer } from "../config/wedding";

const whatsappUrl = `https://wa.me/${designer.whatsappNumber}?text=${encodeURIComponent(designer.whatsappMessage)}`;
---

<section
  class="relative z-40 border-t"
  style={`background-color: ${colors.bgWarm}; border-color: ${colors.primaryLight}1f`}
>
  <div class="relative z-10 py-6 px-6 text-center max-w-md mx-auto">
    <p
      class="font-raleway text-[0.65rem] tracking-[0.3em] uppercase intersect:motion-preset-fade-sm intersect:motion-duration-1000 intersect-once"
      style={`color: ${colors.textMuted}; opacity: 0.75`}
    >
      {designer.ctaMessage}
    </p>

    <a
      href={whatsappUrl}
      target="_blank"
      rel="noopener noreferrer"
      aria-label={`Contactar a ${designer.name} por WhatsApp`}
      class="mt-3 inline-flex items-center gap-2 font-raleway text-[0.7rem] tracking-[0.15em] intersect:motion-preset-fade-sm intersect:motion-delay-200 intersect:motion-duration-1000 intersect-once transition-opacity duration-300 hover:opacity-100"
      style={`color: ${colors.primary}; opacity: 0.75`}
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 32 32"
        fill="currentColor"
        class="w-3.5 h-3.5"
        aria-hidden="true"
      >
        <path
          d="M19.11 17.205c-.372 0-1.088 1.39-1.518 1.39a.63.63 0 0 1-.315-.1c-.802-.402-1.504-.817-2.163-1.447-.545-.516-1.146-1.29-1.46-1.963a.426.426 0 0 1-.073-.215c0-.33.99-.945.99-1.49 0-.143-.73-2.09-.832-2.335-.214-.517-.358-.517-.602-.517-.114 0-.229-.012-.343-.012a.948.948 0 0 0-.689.302c-.374.375-1.104 1.123-1.104 2.572 0 1.48 1.017 2.904 1.153 3.09 1.372 1.878 2.917 3.29 5.075 4.148.53.2 2.358.881 2.926.881.52 0 1.517-.235 1.946-.977.187-.315.361-.653.361-1.018 0-.38-1.833-1.307-2.352-1.307zm-2.986 7.41a10.64 10.64 0 0 1-5.463-1.514l-3.908 1.25 1.274-3.779a10.603 10.603 0 0 1-1.64-5.657c0-5.867 4.76-10.643 10.737-10.643 2.848 0 5.506 1.115 7.505 3.14a10.545 10.545 0 0 1 3.106 7.503c0 5.862-4.862 10.635-10.73 10.635zm0-23.413c-7.14 0-12.86 5.72-12.86 12.67 0 2.11.558 4.12 1.618 5.902L3 31l7.287-1.907a13.36 13.36 0 0 0 6.125 1.47c7.125 0 12.86-5.72 12.86-12.67 0-3.362-1.316-6.558-3.704-8.944a12.796 12.796 0 0 0-9.156-3.748z"
        />
      </svg>
      <span>Invitación por {designer.name}</span>
    </a>
  </div>
</section>
